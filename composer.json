{
    "name": "3neti/x-rider",
    "description": "Programmable claimant experience layer for post-claim rider messages, redirects, splash, analytics seams, and future campaign runtimes.",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Lester Hurtado",
            "email": "lester@hurtado.ph"
        }
    ],
    "autoload": {
        "psr-4": {
            "LBHurtado\\XRider\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LBHurtado\\XRider\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LBHurtado\\XRider\\XRiderServiceProvider"
            ]
        }
    },
    "require": {
        "php": ">=8.3",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/routing": "^12.0 || ^13.0",
        "spatie/laravel-data": "^4.17"
    },
    "require-dev": {
        "orchestra/testbench": "^10.3 || ^11.0",
        "pestphp/pest": "^3.8 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.2 || ^4.0"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
